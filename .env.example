# Copy this file to ".env" and paste your Anthropic API key.
# Get one at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# Optional: change the port the server listens on (default 3000)
# PORT=3000

# Optional password gate. If you host the game publicly with your own key,
# set this to a password so only people you share it with can play (and use
# your API credit). Leave it blank/unset to run the game open to anyone.
# APP_PASSWORD=choose-a-password
